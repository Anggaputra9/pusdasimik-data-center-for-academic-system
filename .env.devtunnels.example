# ========================================
# KONFIGURASI UNTUK DEVTUNNELS
# ========================================
# Contoh DevTunnels URL: https://abc123xyz.devtunnels.ms

# 1. Ganti APP_URL dengan URL DevTunnels Anda
APP_URL=https://YOUR_DEVTUNNEL_URL.devtunnels.ms

# 2. Tambahkan domain DevTunnels ke Sanctum stateful domains
# Format: domain tanpa https://
SANCTUM_STATEFUL_DOMAINS=YOUR_DEVTUNNEL_URL.devtunnels.ms,localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# 3. Session domain harus null atau sesuai dengan DevTunnels domain
SESSION_DOMAIN=null

# ========================================
# CONTOH KONFIGURASI LENGKAP
# ========================================
# Jika DevTunnels URL Anda: https://abc123xyz.devtunnels.ms
# Maka konfigurasinya:
#
# APP_URL=https://abc123xyz.devtunnels.ms
# SANCTUM_STATEFUL_DOMAINS=abc123xyz.devtunnels.ms,localhost,localhost:3000,127.0.0.1
# SESSION_DOMAIN=null

# ========================================
# CARA SHARE KE SISTEM LAIN
# ========================================
# Berikan informasi berikut ke sistem-sistem yang akan mengirim data:
#
# BASE URL: https://YOUR_DEVTUNNEL_URL.devtunnels.ms
# 
# API Endpoints yang tersedia:
# - POST /api/peminjaman/kirim       (dari sistem-perpustakaan)
# - POST /api/presensi/kirim         (dari sistem-presensi)
# - POST /api/pengajuan-judul/kirim  (dari sistem-pengajuan-judul)
#
# Authentication: Bearer Token (Sanctum)
# Header yang dibutuhkan:
#   Authorization: Bearer {token_dari_sanctum}
#   Content-Type: application/json
#   Accept: application/json
